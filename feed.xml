                <div class="gallery-wrapper"><div class="gallery" data-is-empty="false" data-translation="Add images" data-columns="2">
<figure class="gallery__item"><a href="https://rudytrnka.com/media/posts/11/gallery/ComfyUI_00444_.png" data-size="1224x1688"><img loading="lazy" src="https://rudytrnka.com/media/posts/11/gallery/ComfyUI_00444_-thumbnail.png" alt="" width="768" height="1059"></a></figure>
