<figure class="gallery__item"><a href="https://rudytrnka.com/media/posts/2/gallery/CARRIE_LOGO-whitebg.png" data-size="371x164"><img loading="lazy" src="https://rudytrnka.com/media/posts/2/gallery/CARRIE_LOGO-whitebg-thumbnail.png" alt="" width="371" height="164"></a></figure>
<figure class="gallery__item"><a href="https://rudytrnka.com/media/posts/2/gallery/1logo.jpg" data-size="474x647"><img loading="lazy" src="https://rudytrnka.com/media/posts/2/gallery/1logo-thumbnail.jpg" alt="" width="474" height="647"></a></figure>
