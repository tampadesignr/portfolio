<figure class="gallery__item"><a href="https://rudytrnka.com/media/posts/2/gallery/Boogu_image_edit_00004_.png" data-size="1024x1024"><img loading="lazy" src="https://rudytrnka.com/media/posts/2/gallery/Boogu_image_edit_00004_-thumbnail.png" alt="" width="768" height="768"></a></figure>
